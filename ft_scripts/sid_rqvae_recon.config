train_input_path: "/mnt/fangtinglin/codework/al_sid/SID_generation/datas/reconstruct_data_mask.snappy.parquet"
eval_input_path: ""
model_dir: "experiments/sid_rqvae_recon"

train_config {
    sparse_optimizer {
        adagrad_optimizer {
            lr: 0.001
        }
        constant_learning_rate {
        }
    }
    dense_optimizer {
        adam_optimizer {
            lr: 0.00002
        }
        constant_learning_rate {
        }
    }
    num_epochs: 150
    save_checkpoints_steps: 5000
    log_step_count_steps: 100
}

data_config {
    batch_size: 2048
    dataset_type: ParquetDataset
    fg_mode: FG_DAG
    num_workers: 8
}

feature_configs {
    raw_feature {
        feature_name: "item_emb"
        expression: "item:embedding"
        value_dim: 512
    }
}

model_config {
    feature_groups {
        group_name: "deep"
        feature_names: "item_emb"
        group_type: DEEP
    }
    sid_rqvae {
        input_dim: 512
        embed_dim: 64
        hidden_dims: "256,256"
        codebook: "512,512,512"
        forward_mode: "ste"
        loss_type: "mse"
        kmeans_init: false
        latent_weight: "0.5,0.5"
        embedding_feature_name: "item_emb"
    }
}
